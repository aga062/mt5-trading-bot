# ============================================================================
# Environment Variables for VPS Deployment
# Copy this file to /opt/mt5-bot/backend/.env on your VPS
# ============================================================================

# JWT Secret Key - CHANGE THIS! Make it long and random (at least 32 chars)
# Example: MyBotKey2024-GoldTrading-XAUUSD-Secret-9876543210
SECRET_KEY=change-this-to-a-very-long-random-secret-key-here

# Database path on the VPS
DATABASE_URL=/opt/mt5-bot/backend/trading.db

# Allowed frontend domains (comma-separated, no spaces)
# For production, list your exact domains. Use "*" only for testing.
CORS_ORIGINS=https://algotradeai.net,https://www.algotradeai.net

# Optional: Encryption key for MT5 credentials (32 bytes recommended)
# CREDENTIAL_ENCRYPTION_KEY=change-this-to-a-32-byte-key-in-production!
